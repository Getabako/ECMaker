<div class="page-wrap">
  <h1>Cart</h1>
  {% if cart.item_count > 0 %}
    {% form 'cart', cart %}
      {% for item in cart.items %}
        <div class="cart-line">
          {% if item.image %}
            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title | escape }}"/>
          {% else %}
            <div></div>
          {% endif %}
          <div>
            <a class="cart-line__title" href="{{ item.url }}">{{ item.product.title }}</a>
            {%- if item.variant.title and item.variant.title != 'Default Title' -%}
              <div class="cart-line__variant">{{ item.variant.title }}</div>
            {%- endif -%}
          </div>
          <input class="cart-line__qty" type="number" name="updates[]" value="{{ item.quantity }}" min="0"/>
          <div style="font-weight:600">{{ item.final_line_price | money }}</div>
        </div>
      {% endfor %}
      <div class="cart-summary">
        <button type="submit" name="update" class="btn btn--ghost">Update</button>
        <div class="cart-total">Total: {{ cart.total_price | money }}</div>
      </div>
      <button type="submit" name="checkout" class="btn btn--primary" style="margin-top:24px;width:100%">Checkout</button>
    {% endform %}
  {% else %}
    <p style="color:var(--ink-dim)">カートは空です。 <a href="{{ routes.collections_url }}/all" style="color:var(--accent)">商品を見る →</a></p>
  {% endif %}
</div>
