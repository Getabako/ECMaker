<div class="page-wrap page-wrap--wide">
  <h1>Search</h1>
  <form action="{{ routes.search_url }}" method="get" style="margin:24px 0">
    <input name="q" value="{{ search.terms | escape }}" placeholder="Search…" style="padding:12px 18px;border:1px solid var(--line);border-radius:8px;width:100%;max-width:400px"/>
    <button type="submit" class="btn btn--primary" style="margin-left:8px">Search</button>
  </form>
  {% if search.performed %}
    <p style="color:var(--ink-dim)">{{ search.results_count }} results</p>
    <div class="product-grid">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}{% render 'product-card', product: item %}{% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>
