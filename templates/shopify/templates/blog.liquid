<div class="page-wrap">
  <h1>{{ blog.title }}</h1>
  {% for article in blog.articles %}
    <article style="border-bottom:1px solid var(--line);padding:20px 0">
      <a href="{{ article.url }}" style="font-weight:700;font-size:18px;color:var(--ink)">{{ article.title }}</a>
      <div style="color:var(--ink-dim);font-size:13px;margin-top:4px">{{ article.published_at | date: '%Y.%m.%d' }}</div>
      {%- if article.excerpt != blank -%}
        <div style="color:var(--ink-dim);margin-top:8px">{{ article.excerpt }}</div>
      {%- endif -%}
    </article>
  {% endfor %}
</div>
