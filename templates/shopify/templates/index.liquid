{%- comment -%}
  Hero markup branches on the ECMaker-baked hero type.
  Possible values: image | slider | video-single | video-multi
  All merchant copy is pre-baked via __ECM_*__ sentinels.
{%- endcomment -%}

{%- assign ecm_hero_type = '__ECM_HERO_TYPE__' -%}

<!-- HERO -->
<section class="hero hero--{{ ecm_hero_type }}" aria-label="Hero">
  <div class="hero__media" aria-hidden="true">
    {%- if ecm_hero_type == 'image' -%}
      <img class="hero__image" src="__ECM_HERO_IMAGE_URL__" alt="" />
    {%- elsif ecm_hero_type == 'slider' -%}
      <div class="hero__slider" id="heroSlider">
        <img class="hero__slide is-active" src="__ECM_HERO_SLIDER_FIRST__" alt="" />
      </div>
    {%- elsif ecm_hero_type == 'video-single' -%}
      <video class="hero__video hero__video--single" id="heroVideoSingle"
             src="__ECM_HERO_VIDEO_FIRST__"
             muted playsinline autoplay loop preload="auto"></video>
    {%- elsif ecm_hero_type == 'video-multi' -%}
      <video class="hero__video hero__video--a" id="heroVideoA" muted playsinline autoplay preload="auto"></video>
      <video class="hero__video hero__video--b" id="heroVideoB" muted playsinline preload="auto"></video>
    {%- endif -%}
    <div class="hero__overlay"></div>
  </div>

  {%- if ecm_hero_type == 'video-multi' -%}
    <button class="hero__nav hero__nav--prev" id="heroPrev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18 9 12l6-6"/></svg>
    </button>
    <button class="hero__nav hero__nav--next" id="heroNext" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  {%- endif -%}

  <div class="hero__copy">
    {%- assign hero_eyebrow = '__ECM_HERO_EYEBROW__' -%}
    {%- if hero_eyebrow != blank -%}
      <div class="hero__eyebrow">{{ hero_eyebrow }}</div>
    {%- endif -%}
    <h1 class="hero__title">__ECM_HERO_HEADLINE__</h1>
    {%- assign hero_sub = '__ECM_HERO_SUBTITLE__' -%}
    {%- if hero_sub != blank -%}
      <p class="hero__sub">{{ hero_sub }}</p>
    {%- endif -%}
    <div class="hero__ctas">
      <a class="btn btn--primary" href="__ECM_HERO_CTA_PRIMARY_URL__">__ECM_HERO_CTA_PRIMARY_LABEL__</a>
      {%- assign cta2_label = '__ECM_HERO_CTA_SECONDARY_LABEL__' -%}
      {%- if cta2_label != blank -%}
        <a class="btn btn--ghost" href="__ECM_HERO_CTA_SECONDARY_URL__">{{ cta2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- PRODUCTS -->
<section class="section" id="shop">
  <div class="section__head">
    <h2 class="section__title">__ECM_PRODUCTS_TITLE__</h2>
    {%- assign prod_sub = '__ECM_PRODUCTS_SUBTITLE__' -%}
    {%- if prod_sub != blank -%}
      <p class="section__sub">{{ prod_sub }}</p>
    {%- endif -%}
  </div>

  {%- assign all_prods = collections.all.products -%}
  {%- if all_prods.size > 0 -%}
    <div class="product-grid">
      {%- for product in all_prods limit: 12 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
    <div class="section__cta">
      <a class="btn btn--ghost" href="{{ routes.collections_url }}/all">View All Products</a>
    </div>
  {%- else -%}
    <p class="section__empty">商品はまだ登録されていません。</p>
  {%- endif -%}
</section>

<!-- BRANDS -->
<section class="section section--soft ecm-brands" id="brands" data-brands="__ECM_BRANDS_JSON__">
  <div class="section__head">
    <h2 class="section__title">__ECM_BRANDS_TITLE__</h2>
  </div>
  <div class="brand-grid" id="ecmBrandGrid"></div>
</section>

<!-- ABOUT / STORE -->
<section class="section about" id="about">
  <div class="about__copy">
    <div class="section__head">
      <h2 class="section__title">__ECM_ABOUT_TITLE__</h2>
    </div>
    {%- assign about_quote = '__ECM_ABOUT_QUOTE__' -%}
    {%- if about_quote != blank -%}
      <p class="about__quote">{{ about_quote }}</p>
    {%- endif -%}
    {%- assign about_body = '__ECM_ABOUT_BODY__' -%}
    {%- if about_body != blank -%}
      <p class="about__body">{{ about_body }}</p>
    {%- endif -%}

    <dl class="about__info">
      {%- assign addr = '__ECM_STORE_ADDRESS__' -%}
      {%- if addr != blank -%}
        <div><dt>Address</dt><dd>{{ addr }}</dd></div>
      {%- endif -%}
      {%- assign hours = '__ECM_STORE_HOURS__' -%}
      {%- if hours != blank -%}
        <div><dt>Hours</dt><dd>{{ hours }}</dd></div>
      {%- endif -%}
      {%- assign access = '__ECM_STORE_ACCESS__' -%}
      {%- if access != blank -%}
        <div><dt>Access</dt><dd>{{ access }}</dd></div>
      {%- endif -%}
    </dl>

    <div class="about__ctas">
      <a class="btn btn--primary" href="{{ routes.root_url }}pages/contact">Contact</a>
      {%- assign maps_q = '__ECM_STORE_MAPS_QUERY__' -%}
      {%- if maps_q != blank -%}
        <a class="btn btn--ghost" href="https://www.google.com/maps/dir/?api=1&destination={{ maps_q | url_encode }}" target="_blank" rel="noopener noreferrer">Get Directions</a>
      {%- endif -%}
    </div>
  </div>

  <div class="about__side">
    {%- if maps_q != blank -%}
      <div class="about__map">
        <iframe loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q={{ maps_q | url_encode }}&output=embed"
          title="Map"></iframe>
      </div>
    {%- endif -%}

    <div class="faq ecm-faq" id="ecmFaq" data-faqs="__ECM_FAQS_JSON__"></div>
  </div>
</section>

<!-- SOCIAL -->
{%- assign insta_off = '__ECM_INSTAGRAM_OFFICIAL__' -%}
{%- assign insta_sub = '__ECM_INSTAGRAM_SECONDARY__' -%}
{%- if insta_off != blank or insta_sub != blank -%}
<section class="section section--soft" id="social">
  <div class="section__head">
    <h2 class="section__title">__ECM_SOCIAL_TITLE__</h2>
  </div>
  <div class="social-grid">
    {%- if insta_off != blank -%}
      <a class="social-card" href="{{ insta_off }}" target="_blank" rel="noopener noreferrer">
        <div class="social-card__tag">Instagram</div>
        <div class="social-card__handle">__ECM_INSTAGRAM_OFFICIAL_HANDLE__</div>
        <div class="social-card__cta">Follow →</div>
      </a>
    {%- endif -%}
    {%- if insta_sub != blank -%}
      <a class="social-card" href="{{ insta_sub }}" target="_blank" rel="noopener noreferrer">
        <div class="social-card__tag">Instagram</div>
        <div class="social-card__handle">__ECM_INSTAGRAM_SECONDARY_HANDLE__</div>
        <div class="social-card__cta">Follow →</div>
      </a>
    {%- endif -%}
  </div>
</section>
{%- endif -%}
