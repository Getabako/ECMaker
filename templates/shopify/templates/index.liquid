  <button class="hv-nav next" id="hvNext" aria-label="Next track" title="Next">
    <span class="hv-nav-face"><span class="hv-nav-glyph">⏭</span></span>
  </button>
  <div class="copy">
    <div class="tag">Niigata · Cool Chill · est. 2023</div>
    <h1 id="heroHead">
