<!-- SVG turbulence filter (smoke warp) -->
<svg width="0" height="0" style="position:absolute">
  <defs>
    <filter id="turb">
      <feTurbulence type="fractalNoise" baseFrequency="0.012 0.018" numOctaves="2" seed="3">
        <animate attributeName="baseFrequency" dur="22s" values="0.012 0.018;0.02 0.012;0.012 0.018" repeatCount="indefinite"/>
      </feTurbulence>
      <feDisplacementMap in="SourceGraphic" scale="80"/>
    </filter>
  </defs>
</svg>

<!-- INTRO -->
