    </div>
    <div class="spindle"></div>
    <div class="tonearm" id="tonearm">
      <div class="stem"><div class="head"></div></div>
      <div class="pivot"></div>
    </div>

    <div class="deck-controls">
      <button id="btnPlay" title="Play/Pause">▶</button>
      <button id="btnStop" title="Stop">■</button>
      <div class="vol">
        <span style="font-size:11px;letter-spacing:.2em">VOL</span>
        <input id="vol" type="range" min="0" max="1" step="0.01" value="0.7"/>
