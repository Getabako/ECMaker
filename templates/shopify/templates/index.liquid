<!-- SHOP -->
<section id="shop">
  <div class="sec-head">
    <div>
      <div class="num">— 001 / DROP</div>
      <h2>THE COLLECTION.</h2>
    </div>
    <p>厳選されたカートリッジ、コンセントレート、ディスプレイ。それぞれが一つの「リリース」。在庫は常に有限。<br/><span style="color:var(--acid);font-size:11px;letter-spacing:.25em;text-transform:uppercase;display:inline-block;margin-top:8px">→ 各商品をタップすると Shopify の商品ページへ遷移します</span></p>
  </div>

  {%- assign all_prods = collections.all.products -%}
  {%- assign total = all_prods | size -%}
  {%- assign half = total | divided_by: 2 -%}
  {%- assign rem = total | modulo: 2 -%}
  {%- if rem != 0 -%}{%- assign half = half | plus: 1 -%}{%- endif -%}
  {%- assign bot_size = total | minus: half -%}
  {%- if bot_size <= 0 -%}{%- assign bot_size = half -%}{%- endif -%}

  <div class="grid" id="productGrid">
    <div class="scroll-row">
      <div class="scroll-track scroll-left" style="--n:{{ half }}">
        {%- for i in (1..2) -%}
          {%- for product in all_prods limit: half -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
    <div class="scroll-row">
      <div class="scroll-track scroll-right" style="--n:{{ bot_size }}">
        {%- for i in (1..2) -%}
          {%- if total > half -%}
            {%- for product in all_prods offset: half -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          {%- else -%}
            {%- for product in all_prods limit: half -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div style="text-align:center;margin-top:60px">
    <a class="btn" href="{{ routes.collections_url }}/all">VIEW ALL PRODUCTS →</a>
  </div>
</section>

