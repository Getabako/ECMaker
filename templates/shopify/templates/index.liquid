<!-- HERO -->
<section class="hero" aria-label="Hero">
  <div class="hero__media" aria-hidden="true">
    <video class="hero__video hero__video--a" id="heroVideoA" muted playsinline autoplay preload="auto"></video>
    <video class="hero__video hero__video--b" id="heroVideoB" muted playsinline preload="auto"></video>
    <div class="hero__wipe" id="heroWipe"></div>
    <div class="hero__overlay"></div>
  </div>

  <button class="hero__nav hero__nav--prev" id="heroPrev" aria-label="Previous">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18 9 12l6-6"/></svg>
  </button>
  <button class="hero__nav hero__nav--next" id="heroNext" aria-label="Next">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
  </button>

  <div class="hero__copy">
    {%- if settings.hero_eyebrow != blank -%}
      <div class="hero__eyebrow">{{ settings.hero_eyebrow }}</div>
    {%- endif -%}
    <h1 class="hero__title">{{ settings.hero_headline | default: shop.name }}</h1>
    {%- if settings.hero_subtitle != blank -%}
      <p class="hero__sub">{{ settings.hero_subtitle }}</p>
    {%- endif -%}
    <div class="hero__ctas">
      <a class="btn btn--primary" href="{{ settings.hero_cta_primary_url | default: routes.collections_url | append: '/all' }}">
        {{ settings.hero_cta_primary_label | default: 'SHOP NOW' }}
      </a>
      {%- if settings.hero_cta_secondary_label != blank -%}
        <a class="btn btn--ghost" href="{{ settings.hero_cta_secondary_url | default: '#about' }}">
          {{ settings.hero_cta_secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- PRODUCTS -->
<section class="section" id="shop">
  <div class="section__head">
    <h2 class="section__title">{{ settings.products_section_title | default: 'Products' }}</h2>
    {%- if settings.products_section_subtitle != blank -%}
      <p class="section__sub">{{ settings.products_section_subtitle }}</p>
    {%- endif -%}
  </div>

  {%- assign all_prods = collections.all.products -%}
  {%- if all_prods.size > 0 -%}
    <div class="product-grid">
      {%- for product in all_prods limit: 12 -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>
    <div class="section__cta">
      <a class="btn btn--ghost" href="{{ routes.collections_url }}/all">View All Products</a>
    </div>
  {%- else -%}
    <p class="section__empty">商品はまだ登録されていません。</p>
  {%- endif -%}
</section>

<!-- BRANDS -->
{%- assign brands_text = settings.brands_list | default: '' -%}
{%- if brands_text != blank -%}
<section class="section section--soft" id="brands">
  <div class="section__head">
    <h2 class="section__title">{{ settings.brands_section_title | default: 'Brands' }}</h2>
  </div>
  <div class="brand-grid">
    {%- assign brand_items = brands_text | split: ',' -%}
    {%- for b in brand_items -%}
      <div class="brand-grid__item">{{ b | strip }}</div>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

<!-- ABOUT / STORE -->
<section class="section about" id="about">
  <div class="about__copy">
    <div class="section__head">
      <h2 class="section__title">{{ settings.about_section_title | default: 'About' }}</h2>
    </div>
    {%- if settings.about_quote != blank -%}
      <p class="about__quote">{{ settings.about_quote }}</p>
    {%- endif -%}
    {%- if settings.about_body != blank -%}
      <p class="about__body">{{ settings.about_body }}</p>
    {%- endif -%}

    <dl class="about__info">
      {%- if settings.store_address != blank -%}
        <div><dt>Address</dt><dd>{{ settings.store_address }}</dd></div>
      {%- endif -%}
      {%- if settings.store_hours != blank -%}
        <div><dt>Hours</dt><dd>{{ settings.store_hours }}</dd></div>
      {%- endif -%}
      {%- if settings.store_access != blank -%}
        <div><dt>Access</dt><dd>{{ settings.store_access }}</dd></div>
      {%- endif -%}
    </dl>

    <div class="about__ctas">
      <a class="btn btn--primary" href="{{ routes.root_url }}pages/contact">Contact</a>
      {%- if settings.store_maps_query != blank -%}
        <a class="btn btn--ghost" href="https://www.google.com/maps/dir/?api=1&destination={{ settings.store_maps_query | url_encode }}" target="_blank" rel="noopener noreferrer">Get Directions</a>
      {%- endif -%}
    </div>
  </div>

  <div class="about__side">
    {%- if settings.store_maps_query != blank -%}
      <div class="about__map">
        <iframe loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q={{ settings.store_maps_query | url_encode }}&output=embed"
          title="Map"></iframe>
      </div>
    {%- endif -%}

    {%- assign faq_text = settings.faq_list | default: '' -%}
    {%- if faq_text != blank -%}
      <div class="faq">
        {%- assign faq_items = faq_text | split: '|' -%}
        {%- for item in faq_items -%}
          {%- assign parts = item | split: '::' -%}
          {%- if parts.size >= 2 -%}
            <details>
              <summary>{{ parts[0] | strip }}</summary>
              <p>{{ parts[1] | strip }}</p>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<!-- SOCIAL -->
{%- if settings.instagram_official != blank or settings.instagram_secondary != blank -%}
<section class="section section--soft" id="social">
  <div class="section__head">
    <h2 class="section__title">{{ settings.social_section_title | default: 'Follow Us' }}</h2>
  </div>
  <div class="social-grid">
    {%- if settings.instagram_official != blank -%}
      <a class="social-card" href="{{ settings.instagram_official }}" target="_blank" rel="noopener noreferrer">
        <div class="social-card__tag">Instagram</div>
        <div class="social-card__handle">{{ settings.instagram_official_handle | default: '@official' }}</div>
        <div class="social-card__cta">Follow →</div>
      </a>
    {%- endif -%}
    {%- if settings.instagram_secondary != blank -%}
      <a class="social-card" href="{{ settings.instagram_secondary }}" target="_blank" rel="noopener noreferrer">
        <div class="social-card__tag">Instagram</div>
        <div class="social-card__handle">{{ settings.instagram_secondary_handle | default: '@sub' }}</div>
        <div class="social-card__cta">Follow →</div>
      </a>
    {%- endif -%}
  </div>
</section>
{%- endif -%}
