<div style="max-width:600px;margin:120px auto;padding:0 28px;color:var(--ink);text-align:center">
  <h1>GIFT CARD</h1>
  <div style="font-size:32px;font-weight:900;color:var(--acid)">{{ gift_card.initial_value | money }}</div>
  <div style="font-family:monospace;background:var(--card);padding:18px;margin:24px 0;border:1px solid var(--line)">{{ gift_card.code | format_code }}</div>
</div>
