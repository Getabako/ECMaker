<div class="page-wrap" style="text-align:center">
  <h1>Gift Card</h1>
  <div style="font-size:32px;font-weight:700;color:var(--accent);margin:16px 0">{{ gift_card.initial_value | money }}</div>
  <div style="font-family:monospace;background:var(--bg-soft);padding:18px;margin:24px 0;border:1px solid var(--line);border-radius:var(--radius)">{{ gift_card.code | format_code }}</div>
</div>
