<div style="max-width:420px;margin:120px auto;padding:0 28px;color:var(--ink)">
  <h1>RESET PASSWORD</h1>
  {% form 'reset_customer_password' %}<input type="password" name="customer[password]" placeholder="New password" required style="width:100%;background:var(--card);color:var(--ink);border:1px solid var(--line);padding:12px;margin:8px 0"/><input type="password" name="customer[password_confirmation]" placeholder="Confirm" required style="width:100%;background:var(--card);color:var(--ink);border:1px solid var(--line);padding:12px;margin:8px 0"/><button type="submit" class="btn primary" style="width:100%">RESET</button>{% endform %}
