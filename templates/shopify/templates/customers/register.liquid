<div class="page-wrap" style="max-width:480px">
  <h1>Create Account</h1>
  {% form 'create_customer' %}
    {{ form.errors | default_errors }}
    <label style="display:block;margin:12px 0 4px">First Name</label>
    <input name="customer[first_name]" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:8px"/>
    <label style="display:block;margin:12px 0 4px">Last Name</label>
    <input name="customer[last_name]" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:8px"/>
    <label style="display:block;margin:12px 0 4px">Email</label>
    <input type="email" name="customer[email]" required style="width:100%;padding:12px;border:1px solid var(--line);border-radius:8px"/>
    <label style="display:block;margin:12px 0 4px">Password</label>
    <input type="password" name="customer[password]" required style="width:100%;padding:12px;border:1px solid var(--line);border-radius:8px"/>
    <button type="submit" class="btn btn--primary" style="margin-top:20px;width:100%">Create</button>
  {% endform %}
</div>
