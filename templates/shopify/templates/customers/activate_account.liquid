<div class="page-wrap" style="max-width:480px">
  <h1>Activate Account</h1>
  {% form 'activate_customer_password' %}
    {{ form.errors | default_errors }}
    <label style="display:block;margin:12px 0 4px">Password</label>
    <input type="password" name="customer[password]" required style="width:100%;padding:12px;border:1px solid var(--line);border-radius:8px"/>
    <label style="display:block;margin:12px 0 4px">Confirm Password</label>
    <input type="password" name="customer[password_confirmation]" required style="width:100%;padding:12px;border:1px solid var(--line);border-radius:8px"/>
    <button type="submit" class="btn btn--primary" style="margin-top:20px;width:100%">Activate</button>
  {% endform %}
</div>
