<div class="page-wrap page-wrap--wide">
  <a href="{{ routes.collections_url }}/all" style="font-size:13px;color:var(--ink-dim)">← Back</a>
  <h1 style="margin-top:16px">{{ product.title }}</h1>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start" class="product-layout">
    <div>
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" style="width:100%;border-radius:var(--radius);border:1px solid var(--line)"/>
      {%- endif -%}
    </div>
    <div>
      <div style="font-size:24px;font-weight:700;margin-bottom:16px">{{ product.price | money }}</div>
      <div style="color:var(--ink-dim);line-height:1.8;margin-bottom:32px">{{ product.description }}</div>
      {% form 'product', product %}
        {%- if product.variants.size > 1 -%}
          <select name="id" style="padding:12px;border:1px solid var(--line);border-radius:8px;margin-bottom:16px;width:100%">
            {% for v in product.variants %}
              <option value="{{ v.id }}"{% if v.available == false %} disabled{% endif %}>{{ v.title }} — {{ v.price | money }}</option>
            {% endfor %}
          </select>
        {%- else -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}"/>
        {%- endif -%}
        <button type="submit" class="btn btn--primary" style="width:100%">Add to Cart</button>
      {% endform %}
    </div>
  </div>
</div>
<style>
  @media (max-width: 720px) {
    .product-layout { grid-template-columns: 1fr !important; }
  }
</style>
