<!doctype html>
<html lang="{{ shop.locale }}">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<title>{% if template == 'index' %}{{ shop.name }} — UNDERGROUND CBD SHOP{% else %}{{ page_title }}{% if page_title != shop.name %} — {{ shop.name }}{% endif %}{% endif %}</title>
<meta name="description" content="{% if page_description != blank %}{{ page_description | escape }}{% else %}新潟駅から3分。日本一ピースなCBDショップ。Neo plus AID。{% endif %}" />
<link rel="canonical" href="{{ canonical_url }}" />
<link rel="preload" as="image" href="{{ 'delivery-banner.jpg' | asset_url }}" />
{{ 'theme.css' | asset_url | stylesheet_tag }}
<script>
  (function(){
    // Hard-coded defaults — these are the 6 Shopify Files video URLs.
    // Theme-setting URLs below override these per-slot if you fill them in.
    var defaults = [
      "https://cdn.shopify.com/videos/c/o/v/ba179035550d4870a8f6364ea65179ee.mp4",
      "https://cdn.shopify.com/videos/c/o/v/200276f068a247439eae4b463b924674.mp4",
      "https://cdn.shopify.com/videos/c/o/v/e00531824d344b9a8f8e58cfbfa54d6f.mp4",
      "https://cdn.shopify.com/videos/c/o/v/dbd8211a3c0043b696885b92996b1121.mp4",
      "https://cdn.shopify.com/videos/c/o/v/ee23d6d7fe8a43978cf6ade83b8f1b80.mp4",
      "https://cdn.shopify.com/videos/c/o/v/02739b1e76e24400a14edaddf5b58c70.mp4"
    ];
    var overrides = [
      {{ settings.hero_video_url_1 | json }},
      {{ settings.hero_video_url_2 | json }},
      {{ settings.hero_video_url_3 | json }},
      {{ settings.hero_video_url_4 | json }},
      {{ settings.hero_video_url_5 | json }},
      {{ settings.hero_video_url_6 | json }}
    ];
    var urls = [];
    for(var i = 0; i < 6; i++){
      var u = (overrides[i] && overrides[i].length > 0) ? overrides[i] : defaults[i];
      if(u) urls.push(u);
    }
    window.NEO_VIDEOS = urls;
  })();
</script>
{{ content_for_header }}
</head>
<body>
{{ content_for_layout }}
<script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
